# gemini-web2api configuration — copy to .env and edit.
# All settings are optional; defaults are shown. Process env vars take
# precedence over values in this file.

# --- Server ---
# Bind address. Accepts "host:port", ":port" (all interfaces), or a bare port.
# Default is localhost-only; use ":8081" or "0.0.0.0:8081" to expose on all interfaces.
GEMINI_LISTEN=127.0.0.1:8081

# --- Upstream request behavior ---
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_DELAY_SEC=2
GEMINI_REQUEST_TIMEOUT_SEC=180

# Gemini web build label. Leave unset (or "auto") to auto-resolve it from the
# Gemini page at startup and refresh periodically (recommended). Set an explicit
# value only if you want to pin a specific build label.
# GEMINI_BL=auto

# --- Defaults ---
GEMINI_DEFAULT_MODEL=gemini-3.5-flash
# Verbose logging: log each incoming request (INFO). Warnings/errors always show.
GEMINI_LOG_REQUESTS=false

# --- Optional Google account / auth (needed for Pro routing) ---
# Account index for non-default Google accounts (the N in /u/N).
GEMINI_AUTH_USER=
# Inline cookie string. For real authentication you need __Secure-1PSID +
# __Secure-1PSIDTS (+ SAPISID for the hash); without __Secure-1PSIDTS requests
# silently fall back to anonymous. Legacy SID/HSID/SSID/APISID are not required.
# e.g. "__Secure-1PSID=...; __Secure-1PSIDTS=...; SAPISID=..."
GEMINI_COOKIE=
# Or a path to a cookie file: a raw "k=v; k=v" cookie string (same format as
# GEMINI_COOKIE). SAPISID must be one of the pairs in the string.
GEMINI_COOKIE_FILE=
# Minutes between automatic __Secure-1PSIDTS rotations (keeps the cookie from
# expiring). A file-backed cookie is rewritten in place; an inline GEMINI_COOKIE is
# rotated in memory only (survives the run, not a restart). 0 disables.
GEMINI_COOKIE_REFRESH_MIN=9

# --- Networking ---
# HTTP(S) proxy, e.g. http://127.0.0.1:7890. If empty, system HTTP_PROXY/HTTPS_PROXY apply.
GEMINI_PROXY=

# --- Client authentication (optional) ---
# Comma-separated list of accepted client API keys (checked as
# `Authorization: Bearer <key>`, x-api-key, x-goog-api-key, or ?key=).
# If empty, all requests are accepted.
GEMINI_API_KEYS=
